{
  "expo": {
    "name": "FlowPlanner",
    "slug": "flowplanner2",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0f2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowplanner.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0f2e"
      },
      "package": "com.flowplanner.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Разрешить FlowPlanner доступ к фото",
          "cameraPermission": "Разрешить FlowPlanner доступ к камере"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "36234124-e576-4d95-b064-716599af2116"
      }
    }
  }
}
